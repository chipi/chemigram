<darktable_style version="1.0"><info><name>sharpen_edge_only</name><description>L3 discrete kind — edge-only sharpening. amount=0.6 with darktable's default radius (2.0 px) and threshold (0.5). Threshold gates sharpening to detected edges only — no texture amplification on flat regions.</description></info><style><plugin><num>0</num><module>1</module><operation>sharpen</operation><op_params>000000409a99193f0000003f</op_params><enabled>1</enabled><blendop_params>gz08eJxjYGBgYAFiCQYYOOHEgAZY0QWAgBGLGANDgz0Ej1Q+dlAx68oBEMbFxwX+AwGIBgCbGCeh</blendop_params><blendop_version>14</blendop_version><multi_priority>0</multi_priority><multi_name></multi_name><multi_name_hand_edited>0</multi_name_hand_edited></plugin></style></darktable_style>
