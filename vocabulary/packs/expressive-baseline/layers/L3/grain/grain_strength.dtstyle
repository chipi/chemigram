<darktable_style version="1.0"><info><name>grain_strength</name><description>Parameterized grain strength (RFC-021). Default 0.0 (no grain); range [0.0, 100.0]. 8 = grain_fine-equivalent, 25 = grain_medium-equivalent, 50 = grain_heavy-equivalent. Coarseness preserved at the dtstyle level (≈darktable default 1600/213.2 ≈ 7.5).</description></info><style><plugin><num>0</num><module>2</module><operation>grain</operation><op_params>02000000c520f040000000000000c842</op_params><enabled>1</enabled><blendop_params>gz08eJxjYGBgYAFiCQYYOOHEgAZY0QWAgBGLGANDgz0Ej1Q+dlAx68oBEMbFxwX+AwGIBgCbGCeh</blendop_params><blendop_version>14</blendop_version><multi_priority>0</multi_priority><multi_name></multi_name><multi_name_hand_edited>0</multi_name_hand_edited></plugin></style></darktable_style>
