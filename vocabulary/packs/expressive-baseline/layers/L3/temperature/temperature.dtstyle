<darktable_style version="1.0"><info><name>temperature</name><description>Parameterized white balance (RFC-021; first multi-parameter ship). Two axes: --param red_coeff=V (warmer image: red↑) and --param blue_coeff=V (cooler image: blue↑). Range [0.5, 4.0] each; both default 1.0 (no shift). Replaces the v1.5.x discrete wb_warm_subtle / wb_cool_subtle entries.</description></info><style><plugin><num>0</num><module>4</module><operation>temperature</operation><op_params>0000803f0000803f0000803f0000807f02000000</op_params><enabled>1</enabled><blendop_params>gz11eJxjYIAACQYYOOHEgAZY0QWAgBGLGANDgz0Ej1Q+dcF/IADRAGpyHQU=</blendop_params><blendop_version>14</blendop_version><multi_priority>0</multi_priority><multi_name></multi_name><multi_name_hand_edited>0</multi_name_hand_edited></plugin></style></darktable_style>
