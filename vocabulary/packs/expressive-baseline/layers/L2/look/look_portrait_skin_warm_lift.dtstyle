<darktable_style version="1.0"><info><name>look_portrait_skin_warm_lift</name><description>Subject-region warm + brighten. Slight warm temperature (+0.04 red) + exposure +0.2 EV. Pre-baked with mask_skin_region so the lift scopes to skin without affecting clothing or background. Pairs with skin_uniformity for a complete portrait skin pass.</description><iop_list>colorin,demosaic,temperature,exposure,colorbalancergb,bilat,grain,sigmoid,colorout</iop_list></info><style><plugin><num>10</num><module>2</module><operation>temperature</operation><op_params>b81e853f0000803f48e17a3f0000807f02000000</op_params><enabled>1</enabled><blendop_params>gz08eJxjYGBgYAFiCQYYOOHEgAZY0QWAgBGLGANDgz0Ej1Q+dlAx68oBEMbFxwX+AwGIBgCbGCeh</blendop_params><blendop_version>14</blendop_version><multi_priority>0</multi_priority><multi_name></multi_name><multi_name_hand_edited>0</multi_name_hand_edited></plugin><plugin><num>11</num><module>7</module><operation>exposure</operation><op_params>00000000000080b9cdcc4c3e00004842000080c00100000001000000</op_params><enabled>1</enabled><blendop_params>gz08eJxjYGBgYAFiCQYYOOHEgAZY0QWAgBGLGANDgz0Ej1Q+dlAx68oBEMbFxwX+AwGIBgCbGCeh</blendop_params><blendop_version>14</blendop_version><multi_priority>0</multi_priority><multi_name></multi_name><multi_name_hand_edited>0</multi_name_hand_edited></plugin></style></darktable_style>
